'use client';

import { useEffect, useState, useMemo } from 'react';
import { useRouter } from 'next/navigation';
import { signOut } from 'next-auth/react';
import Link from 'next/link';
import { motion, AnimatePresence } from 'framer-motion';
import {
  FaEdit,
  FaCheck,
  FaTimes,
  FaCamera,
  FaTrash,
  FaSignOutAlt,
  FaUserShield,
  FaEye,
  FaEyeSlash,
  FaHeart,
  FaUserPlus,
  FaBookmark,
  FaStar,
  FaLayerGroup,
  FaLaugh,
  FaThumbtack,
  FaTwitter,
  FaInstagram,
  FaYoutube,
  FaTiktok,
  FaImdb,
  FaGlobe,
  FaSave,
  FaHome,
  FaCalendar,
} from 'react-icons/fa';
import { SiLetterboxd } from 'react-icons/si';
import Navbar from '@/components/layout/navbar';
import Badge from '@/components/Badge';

export default function PrivateProfilePage() {
  const router = useRouter();
  
  // User & Profile State
  const [currentUser, setCurrentUser] = useState<any>(null);
  const [profile, setProfile] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  
  // Edit Mode States
  const [isEditMode, setIsEditMode] = useState(false);
  const [isSaving, setIsSaving] = useState(false);
  const [editedProfile, setEditedProfile] = useState<any>({});
  
  // Stats
  const [followers, setFollowers] = useState(0);
  const [following, setFollowing] = useState(0);
  const [counts, setCounts] = useState({
    watched: 0,
    watchlist: 0,
    reviews: 0,
    tierLists: 0,
    memes: 0,
  });
  
  // Heroes data for badges
  const [heroesData, setHeroesData] = useState<any[]>([]);
  
  // Image upload states
  const [isUploadingAvatar, setIsUploadingAvatar] = useState(false);
  const [isUploadingBanner, setIsUploadingBanner] = useState(false);
  
  // Validation errors
  const [errors, setErrors] = useState<any>({});

  // Load current user
  useEffect(() => {
    async function loadUser() {
      try {
        const res = await fetch('/api/auth/me');
        if (!res.ok) {
          router.push('/signin');
          return;
        }
        const data = await res.json();
        setCurrentUser(data);
      } catch (error) {
        console.error('Failed to load user:', error);
        router.push('/signin');
      }
    }
    loadUser();
  }, [router]);

  // Load profile
  useEffect(() => {
    async function loadProfile() {
      if (!currentUser?.profile?.username) return;

      setLoading(true);
      try {
        const res = await fetch(`/api/profile/${currentUser.profile.username}`);
        if (res.ok) {
          const data = await res.json();
          setProfile(data.profile);
          setEditedProfile(data.profile);
          setFollowers(data.followers || 0);
          setFollowing(data.following || 0);
          setCounts(data.counts || {
            watched: 0,
            watchlist: 0,
            reviews: 0,
            tierLists: 0,
            memes: 0,
          });
        }
      } catch (error) {
        console.error('Failed to load profile:', error);
      } finally {
        setLoading(false);
      }
    }

    loadProfile();
  }, [currentUser]);

  // Load heroes data
  useEffect(() => {
    async function loadHeroes() {
      try {
        const res = await fetch('/data/heroes.json');
        if (res.ok) {
          const data = await res.json();
          setHeroesData(data);
        }
      } catch (error) {
        console.error('Failed to load heroes:', error);
      }
    }
    loadHeroes();
  }, []);

  // Handle field change
  function handleFieldChange(field: string, value: any) {
    setEditedProfile((prev: any) => ({
      ...prev,
      [field]: value,
    }));
    // Clear error for this field
    setErrors((prev: any) => ({
      ...prev,
      [field]: null,
    }));
  }

  // Validate profile
  function validateProfile() {
    const newErrors: any = {};

    if (editedProfile.username && editedProfile.username.length < 3) {
      newErrors.username = 'Username must be at least 3 characters';
    }

    if (editedProfile.bio && editedProfile.bio.length > 500) {
      newErrors.bio = 'Bio must be 500 characters or less';
    }

    if (editedProfile.website && !editedProfile.website.match(/^https?:\/\/.+/)) {
      newErrors.website = 'Website must be a valid URL (http:// or https://)';
    }

    setErrors(newErrors);
    return Object.keys(newErrors).length === 0;
  }

  // Save profile
  async function handleSave() {
    if (!validateProfile()) {
      return;
    }

    setIsSaving(true);
    try {
      const res = await fetch('/api/profile/update', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(editedProfile),
      });

      if (res.ok) {
        const data = await res.json();
        setProfile(data.profile);
        setIsEditMode(false);
        alert('Profile updated successfully!');
      } else {
        const error = await res.json();
        alert(error.error || 'Failed to update profile');
      }
    } catch (error) {
      console.error('Failed to save profile:', error);
      alert('Failed to save profile');
    } finally {
      setIsSaving(false);
    }
  }

  // Cancel editing
  function handleCancel() {
    setEditedProfile(profile);
    setIsEditMode(false);
    setErrors({});
  }

  // Upload avatar
  async function handleAvatarUpload(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0];
    if (!file) return;

    setIsUploadingAvatar(true);
    try {
      const formData = new FormData();
      formData.append('avatar', file);

      const res = await fetch('/api/profile/upload-avatar', {
        method: 'POST',
        body: formData,
      });

      if (res.ok) {
        const data = await res.json();
        setProfile((prev: any) => ({ ...prev, avatarUrl: data.avatarUrl }));
        setEditedProfile((prev: any) => ({ ...prev, avatarUrl: data.avatarUrl }));
        alert('Avatar updated!');
      } else {
        alert('Failed to upload avatar');
      }
    } catch (error) {
      console.error('Failed to upload avatar:', error);
      alert('Failed to upload avatar');
    } finally {
      setIsUploadingAvatar(false);
    }
  }

  // Upload banner
  async function handleBannerUpload(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0];
    if (!file) return;

    setIsUploadingBanner(true);
    try {
      const formData = new FormData();
      formData.append('banner', file);

      const res = await fetch('/api/profile/upload-banner', {
        method: 'POST',
        body: formData,
      });

      if (res.ok) {
        const data = await res.json();
        setProfile((prev: any) => ({ ...prev, bannerUrl: data.bannerUrl }));
        setEditedProfile((prev: any) => ({ ...prev, bannerUrl: data.bannerUrl }));
        alert('Banner updated!');
      } else {
        alert('Failed to upload banner');
      }
    } catch (error) {
      console.error('Failed to upload banner:', error);
      alert('Failed to upload banner');
    } finally {
      setIsUploadingBanner(false);
    }
  }

  // Handle sign out
  async function handleSignOut() {
    if (confirm('Are you sure you want to sign out?')) {
      await signOut({ callbackUrl: '/' });
    }
  }

  // Handle delete account
  async function handleDeleteAccount() {
    if (confirm('⚠️ WARNING: This will permanently delete your account and all data. This action cannot be undone!\n\nType "DELETE" to confirm.')) {
      const confirmation = prompt('Type "DELETE" to confirm:');
      if (confirmation === 'DELETE') {
        // TODO: Implement delete account API
        alert('Account deletion not implemented yet');
      }
    }
  }

  // Favorite badges
  const favBadges = useMemo(() => {
    const badges = isEditMode ? editedProfile.favoriteBadges : profile?.favoriteBadges;
    if (!badges || !heroesData.length) return [];
    return badges
      .map((badgeId: string) => heroesData.find((h: any) => h.id === badgeId))
      .filter(Boolean);
  }, [isEditMode, editedProfile.favoriteBadges, profile?.favoriteBadges, heroesData]);

  // Toggle badge in favorites
  function toggleFavoriteBadge(badgeId: string) {
    const current = editedProfile.favoriteBadges || [];
    const index = current.indexOf(badgeId);
    
    if (index > -1) {
      handleFieldChange('favoriteBadges', current.filter((id: string) => id !== badgeId));
    } else if (current.length < 6) {
      handleFieldChange('favoriteBadges', [...current, badgeId]);
    } else {
      alert('You can only have 6 favorite badges');
    }
  }

  if (loading) {
    return (
      <div className="min-h-screen bg-black text-white">
        <Navbar user={currentUser} />
        <div className="flex items-center justify-center h-screen">
          <div className="text-xl">Loading your profile...</div>
        </div>
      </div>
    );
  }

  if (!profile) {
    return (
      <div className="min-h-screen bg-black text-white">
        <Navbar user={currentUser} />
        <div className="flex items-center justify-center h-screen">
          <div className="text-xl">Profile not found</div>
        </div>
      </div>
    );
  }

  const displayProfile = isEditMode ? editedProfile : profile;
  const bannerImage = displayProfile.bannerUrl || displayProfile.coverImage;
  const avatarImage = displayProfile.avatarUrl || currentUser?.image;
  const bioLength = editedProfile.bio?.length || 0;

  return (
    <div className="min-h-screen bg-black text-white">
      <Navbar user={currentUser} />

      {/* Edit Mode Toggle Bar */}
      <div className="sticky top-16 z-40 bg-gray-900/95 backdrop-blur-sm border-b border-gray-800">
        <div className="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
          <div className="flex items-center gap-3">
            {isEditMode ? (
              <>
                <span className="text-red-500 font-semibold">✏️ Edit Mode</span>
                <span className="text-xs text-gray-400">Make changes to your profile</span>
              </>
            ) : (
              <>
                <span className="text-gray-400">View Mode</span>
                <Link href={`/u/${profile.username}`} className="text-xs text-blue-400 hover:underline">
                  View Public Profile
                </Link>
              </>
            )}
          </div>
          
          <div className="flex items-center gap-2">
            {isEditMode ? (
              <>
                <button
                  onClick={handleCancel}
                  disabled={isSaving}
                  className="px-4 py-2 bg-gray-700 hover:bg-gray-600 rounded-lg flex items-center gap-2 transition-all disabled:opacity-50"
                >
                  <FaTimes /> Cancel
                </button>
                <button
                  onClick={handleSave}
                  disabled={isSaving}
                  className="px-4 py-2 bg-red-600 hover:bg-red-700 rounded-lg flex items-center gap-2 transition-all disabled:opacity-50"
                >
                  {isSaving ? (
                    <>
                      <div className="animate-spin">⏳</div> Saving...
                    </>
                  ) : (
                    <>
                      <FaSave /> Save Changes
                    </>
                  )}
                </button>
              </>
            ) : (
              <button
                onClick={() => setIsEditMode(true)}
                className="px-4 py-2 bg-red-600 hover:bg-red-700 rounded-lg flex items-center gap-2 transition-all"
              >
                <FaEdit /> Edit Profile
              </button>
            )}
          </div>
        </div>
      </div>

      {/* Banner Section */}
      <div className="relative w-full h-48 md:h-64 bg-gradient-to-br from-gray-800 to-gray-900">
        {bannerImage && (
          <img
            src={bannerImage}
            alt="Banner"
            className="w-full h-full object-cover"
          />
        )}
        
        {/* Banner Upload (Edit Mode) */}
        {isEditMode && (
          <label className="absolute inset-0 flex items-center justify-center bg-black/50 cursor-pointer hover:bg-black/70 transition-all group">
            <div className="text-center">
              <FaCamera className="text-4xl mb-2 mx-auto group-hover:scale-110 transition-transform" />
              <p className="font-semibold">
                {isUploadingBanner ? 'Uploading...' : 'Change Banner'}
              </p>
              <p className="text-xs text-gray-400">1200x300 recommended</p>
            </div>
            <input
              type="file"
              accept="image/*"
              onChange={handleBannerUpload}
              disabled={isUploadingBanner}
              className="hidden"
            />
          </label>
        )}

        {/* Home Button */}
        <Link
          href="/"
          className="absolute top-4 left-4 bg-black/60 hover:bg-black/80 backdrop-blur-sm p-3 rounded-full transition-all"
        >
          <FaHome />
        </Link>
      </div>

      {/* Profile Header */}
      <div className="max-w-5xl mx-auto px-4 -mt-16 relative z-10">
        <div className="flex flex-col md:flex-row gap-4 items-start md:items-end">
          {/* Avatar */}
          <div className="relative group">
            <div className="w-32 h-32 rounded-full border-4 border-black overflow-hidden bg-gray-800">
              {avatarImage ? (
                <img
                  src={avatarImage}
                  alt={profile.username}
                  className="w-full h-full object-cover"
                />
              ) : (
                <div className="w-full h-full flex items-center justify-center text-4xl font-bold bg-gradient-to-br from-red-600 to-red-800">
                  {profile.username[0].toUpperCase()}
                </div>
              )}
            </div>
            
            {/* Avatar Upload (Edit Mode) */}
            {isEditMode && (
              <label className="absolute inset-0 flex items-center justify-center bg-black/70 rounded-full cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity">
                <FaCamera className="text-2xl" />
                <input
                  type="file"
                  accept="image/*"
                  onChange={handleAvatarUpload}
                  disabled={isUploadingAvatar}
                  className="hidden"
                />
              </label>
            )}
            
            {profile.isOnline && !isEditMode && (
              <div className="absolute bottom-2 right-2 w-4 h-4 bg-green-500 rounded-full border-2 border-black animate-pulse"></div>
            )}
          </div>

          {/* Username & Info */}
          <div className="flex-1 w-full">
            <div className="flex flex-col gap-2">
              {/* Username */}
              {isEditMode ? (
                <div>
                  <input
                    type="text"
                    value={editedProfile.username || ''}
                    onChange={(e) => handleFieldChange('username', e.target.value)}
                    className="text-2xl md:text-3xl font-bold bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 w-full max-w-md focus:border-red-500 focus:outline-none"
                    placeholder="Username"
                  />
                  {errors.username && (
                    <p className="text-red-500 text-sm mt-1">{errors.username}</p>
                  )}
                </div>
              ) : (
                <h1 className="text-2xl md:text-3xl font-bold flex items-center gap-2 flex-wrap">
                  {profile.username}
                  {currentUser?.role === 'admin' && (
                    <span className="text-red-500" title="Admin">
                      <FaUserShield />
                    </span>
                  )}
                </h1>
              )}

              {/* Location & Pronouns */}
              <div className="flex flex-wrap gap-4 text-sm">
                {/* Pronouns */}
                {isEditMode ? (
                  <input
                    type="text"
                    value={editedProfile.pronouns || ''}
                    onChange={(e) => handleFieldChange('pronouns', e.target.value)}
                    className="bg-gray-800 border border-gray-700 rounded px-2 py-1 w-32 focus:border-red-500 focus:outline-none"
                    placeholder="Pronouns"
                  />
                ) : (
                  displayProfile.pronouns && (
                    <span className="text-gray-400">({displayProfile.pronouns})</span>
                  )
                )}

                {/* Location */}
                {isEditMode ? (
                  <div className="flex items-center gap-1">
                    <span>📍</span>
                    <input
                      type="text"
                      value={editedProfile.location || ''}
                      onChange={(e) => handleFieldChange('location', e.target.value)}
                      className="bg-gray-800 border border-gray-700 rounded px-2 py-1 w-40 focus:border-red-500 focus:outline-none"
                      placeholder="Location"
                    />
                  </div>
                ) : (
                  displayProfile.location && (
                    <span className="text-gray-400 flex items-center gap-1">
                      📍 {displayProfile.location}
                    </span>
                  )
                )}

                {/* Join Date */}
                {profile.createdAt && !isEditMode && (
                  <span className="text-gray-400 flex items-center gap-1">
                    <FaCalendar className="text-xs" />
                    Joined {new Date(profile.createdAt).toLocaleDateString()}
                  </span>
                )}
              </div>

              {/* Status Message */}
              {isEditMode ? (
                <div>
                  <input
                    type="text"
                    value={editedProfile.statusMessage || ''}
                    onChange={(e) => handleFieldChange('statusMessage', e.target.value)}
                    className="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 w-full max-w-md focus:border-red-500 focus:outline-none text-sm"
                    placeholder="💬 Status message (optional)"
                    maxLength={100}
                  />
                </div>
              ) : (
                displayProfile.statusMessage && (
                  <p className="text-sm text-gray-400">💬 {displayProfile.statusMessage}</p>
                )
              )}
            </div>
          </div>
        </div>
        {/* Bio Section */}
        <motion.div
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.1 }}
          className="mt-6"
        >
          {isEditMode ? (
            <div>
              <label className="block text-sm font-semibold mb-2">
                Bio ({bioLength}/500)
              </label>
              <textarea
                value={editedProfile.bio || ''}
                onChange={(e) => handleFieldChange('bio', e.target.value)}
                className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 min-h-[120px] focus:border-red-500 focus:outline-none resize-none"
                placeholder="Tell us about yourself..."
                maxLength={500}
              />
              {errors.bio && (
                <p className="text-red-500 text-sm mt-1">{errors.bio}</p>
              )}
            </div>
          ) : (
            displayProfile.bio && (
              <div className="p-4 bg-gray-900/50 backdrop-blur-sm rounded-lg border border-gray-800">
                <p className="whitespace-pre-wrap text-gray-300">{displayProfile.bio}</p>
              </div>
            )
          )}
        </motion.div>

        {/* Favorite Badges Section */}
        <motion.div
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.2 }}
          className="mt-6"
        >
          <h3 className="text-lg font-semibold mb-3 flex items-center gap-2">
            <FaThumbtack className="text-red-500" /> Favorite Badges
            {isEditMode && (
              <span className="text-sm text-gray-400 font-normal">
                (Select up to 6)
              </span>
            )}
          </h3>
          
          {isEditMode ? (
            <div>
              {/* Selected Badges */}
              {favBadges.length > 0 && (
                <div className="flex flex-wrap gap-4 mb-4 p-4 bg-gray-900/50 rounded-lg border border-gray-800">
                  {favBadges.map((badge: any) => (
                    <div key={badge.id} className="relative">
                      <Badge badge={badge} size="medium" />
                      <button
                        onClick={() => toggleFavoriteBadge(badge.id)}
                        className="absolute -top-2 -right-2 bg-red-600 hover:bg-red-700 rounded-full p-1 text-xs"
                      >
                        <FaTimes />
                      </button>
                    </div>
                  ))}
                </div>
              )}
              
              {/* Badge Selector */}
              <div className="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 max-h-96 overflow-y-auto p-4 bg-gray-900/30 rounded-lg border border-gray-800">
                {heroesData.map((badge: any) => {
                  const isSelected = editedProfile.favoriteBadges?.includes(badge.id);
                  return (
                    <button
                      key={badge.id}
                      onClick={() => toggleFavoriteBadge(badge.id)}
                      className={`relative transition-all ${
                        isSelected
                          ? 'ring-2 ring-red-500 opacity-50'
                          : 'hover:scale-105 opacity-100'
                      }`}
                    >
                      <Badge badge={badge} size="small" />
                      {isSelected && (
                        <div className="absolute inset-0 flex items-center justify-center bg-black/50 rounded-lg">
                          <FaCheck className="text-red-500 text-2xl" />
                        </div>
                      )}
                    </button>
                  );
                })}
              </div>
            </div>
          ) : (
            favBadges.length > 0 && (
              <div className="flex flex-wrap gap-4">
                {favBadges.map((badge: any) => (
                  <Badge key={badge.id} badge={badge} size="medium" />
                ))}
              </div>
            )
          )}
        </motion.div>

        {/* Stats Grid */}
        <motion.div
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.3 }}
          className="mt-6"
        >
          <h3 className="text-lg font-semibold mb-3">Your Stats</h3>
          <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
            <StatCard
              icon={<FaHeart />}
              label="Followers"
              value={followers}
              show={displayProfile.showFollowers !== false}
              isEditMode={isEditMode}
              onToggle={() => handleFieldChange('showFollowers', !editedProfile.showFollowers)}
            />
            <StatCard
              icon={<FaUserPlus />}
              label="Following"
              value={following}
              show={displayProfile.showFollowing !== false}
              isEditMode={isEditMode}
              onToggle={() => handleFieldChange('showFollowing', !editedProfile.showFollowing)}
            />
            <StatCard
              icon={<FaEye />}
              label="Watched"
              value={counts.watched}
              show={displayProfile.showWatched !== false}
              isEditMode={isEditMode}
              onToggle={() => handleFieldChange('showWatched', !editedProfile.showWatched)}
            />
            <StatCard
              icon={<FaBookmark />}
              label="Watchlist"
              value={counts.watchlist}
              show={displayProfile.showWatchlist !== false}
              isEditMode={isEditMode}
              onToggle={() => handleFieldChange('showWatchlist', !editedProfile.showWatchlist)}
            />
            <StatCard
              icon={<FaStar />}
              label="Reviews"
              value={counts.reviews}
              show={displayProfile.showReviews !== false}
              isEditMode={isEditMode}
              onToggle={() => handleFieldChange('showReviews', !editedProfile.showReviews)}
            />
            <StatCard
              icon={<FaLayerGroup />}
              label="Tier Lists"
              value={counts.tierLists}
              show={displayProfile.showTierLists !== false}
              isEditMode={isEditMode}
              onToggle={() => handleFieldChange('showTierLists', !editedProfile.showTierLists)}
            />
            {counts.memes > 0 && (
              <StatCard
                icon={<FaLaugh />}
                label="Memes"
                value={counts.memes}
                show={displayProfile.showMemes !== false}
                isEditMode={isEditMode}
                onToggle={() => handleFieldChange('showMemes', !editedProfile.showMemes)}
              />
            )}
          </div>
        </motion.div>

        {/* Social Links Section */}
        <motion.div
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.4 }}
          className="mt-6"
        >
          <h3 className="text-lg font-semibold mb-3">Social Links</h3>
          
          {isEditMode ? (
            <div className="space-y-3">
              <SocialLinkInput
                icon={<FaGlobe />}
                label="Website"
                value={editedProfile.website || ''}
                onChange={(val) => handleFieldChange('website', val)}
                placeholder="https://yourwebsite.com"
                error={errors.website}
              />
              <SocialLinkInput
                icon={<FaTwitter />}
                label="Twitter"
                value={editedProfile.twitterUrl || ''}
                onChange={(val) => handleFieldChange('twitterUrl', val)}
                placeholder="https://twitter.com/username"
              />
              <SocialLinkInput
                icon={<FaInstagram />}
                label="Instagram"
                value={editedProfile.instagramUrl || ''}
                onChange={(val) => handleFieldChange('instagramUrl', val)}
                placeholder="https://instagram.com/username"
              />
              <SocialLinkInput
                icon={<FaYoutube />}
                label="YouTube"
                value={editedProfile.youtubeUrl || ''}
                onChange={(val) => handleFieldChange('youtubeUrl', val)}
                placeholder="https://youtube.com/@username"
              />
              <SocialLinkInput
                icon={<FaTiktok />}
                label="TikTok"
                value={editedProfile.tiktokUrl || ''}
                onChange={(val) => handleFieldChange('tiktokUrl', val)}
                placeholder="https://tiktok.com/@username"
              />
              <SocialLinkInput
                icon={<FaImdb />}
                label="IMDb"
                value={editedProfile.imdbUrl || ''}
                onChange={(val) => handleFieldChange('imdbUrl', val)}
                placeholder="https://imdb.com/user/..."
              />
              <SocialLinkInput
                icon={<SiLetterboxd />}
                label="Letterboxd"
                value={editedProfile.letterboxdUrl || ''}
                onChange={(val) => handleFieldChange('letterboxdUrl', val)}
                placeholder="https://letterboxd.com/username"
              />
            </div>
          ) : (
            (displayProfile.website || displayProfile.twitterUrl || displayProfile.instagramUrl ||
             displayProfile.youtubeUrl || displayProfile.tiktokUrl || displayProfile.imdbUrl ||
             displayProfile.letterboxdUrl) && (
              <div className="flex flex-wrap gap-3">
                {displayProfile.website && (
                  <a
                    href={displayProfile.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex items-center gap-2 bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded-lg transition-all"
                  >
                    <FaGlobe /> Website
                  </a>
                )}
                {displayProfile.twitterUrl && (
                  <a
                    href={displayProfile.twitterUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg transition-all"
                  >
                    <FaTwitter /> Twitter
                  </a>
                )}
                {displayProfile.instagramUrl && (
                  <a
                    href={displayProfile.instagramUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex items-center gap-2 bg-gradient-to-br from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 px-4 py-2 rounded-lg transition-all"
                  >
                    <FaInstagram /> Instagram
                  </a>
                )}
                {displayProfile.youtubeUrl && (
                  <a
                    href={displayProfile.youtubeUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex items-center gap-2 bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg transition-all"
                  >
                    <FaYoutube /> YouTube
                  </a>
                )}
                {displayProfile.tiktokUrl && (
                  <a
                    href={displayProfile.tiktokUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex items-center gap-2 bg-black hover:bg-gray-900 px-4 py-2 rounded-lg transition-all border border-white"
                  >
                    <FaTiktok /> TikTok
                  </a>
                )}
                {displayProfile.imdbUrl && (
                  <a
                    href={displayProfile.imdbUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex items-center gap-2 bg-yellow-600 hover:bg-yellow-700 px-4 py-2 rounded-lg transition-all text-black font-bold"
                  >
                    <FaImdb /> IMDb
                  </a>
                )}
                {displayProfile.letterboxdUrl && (
                  <a
                    href={displayProfile.letterboxdUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex items-center gap-2 bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg transition-all"
                  >
                    <SiLetterboxd /> Letterboxd
                  </a>
                )}
              </div>
            )
          )}
        </motion.div>

        {/* Account Actions */}
        {!isEditMode && (
          <motion.div
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: 0.5 }}
            className="mt-8 pt-8 border-t border-gray-800"
          >
            <h3 className="text-lg font-semibold mb-4">Account Actions</h3>
            <div className="flex flex-wrap gap-3">
              {currentUser?.role === 'admin' && (
                <Link
                  href="/admin/memes"
                  className="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded-lg flex items-center gap-2 transition-all"
                >
                  <FaUserShield /> Admin Panel
                </Link>
              )}
              <button
                onClick={handleSignOut}
                className="px-4 py-2 bg-gray-700 hover:bg-gray-600 rounded-lg flex items-center gap-2 transition-all"
              >
                <FaSignOutAlt /> Sign Out
              </button>
              <button
                onClick={handleDeleteAccount}
                className="px-4 py-2 bg-red-900 hover:bg-red-800 rounded-lg flex items-center gap-2 transition-all"
              >
                <FaTrash /> Delete Account
              </button>
            </div>
          </motion.div>
        )}

        {/* Content Placeholder */}
        <div className="mt-12 pb-12">
          <div className="text-center text-gray-500 py-12 border-t border-gray-800">
            <p>Your content sections will appear here...</p>
            <p className="text-sm mt-2">(Reviews, Tier Lists, Memes, etc.)</p>
          </div>
        </div>
      </div>
    </div>
  );
}

// Stat Card Component
function StatCard({
  icon,
  label,
  value,
  show,
  isEditMode,
  onToggle,
}: {
  icon: React.ReactNode;
  label: string;
  value: number;
  show: boolean;
  isEditMode: boolean;
  onToggle: () => void;
}) {
  return (
    <div
      className={`relative bg-gray-900/50 backdrop-blur-sm rounded-lg p-4 text-center border transition-all ${
        show
          ? 'border-gray-800 hover:border-red-600'
          : 'border-gray-800 opacity-50'
      }`}
    >
      {isEditMode && (
        <button
          onClick={onToggle}
          className="absolute top-2 right-2 text-lg hover:scale-110 transition-transform"
          title={show ? 'Hide from profile' : 'Show on profile'}
        >
          {show ? <FaEye className="text-green-500" /> : <FaEyeSlash className="text-gray-500" />}
        </button>
      )}
      <div className="text-2xl font-bold text-red-500">
        {value.toLocaleString()}
      </div>
      <div className="text-sm text-gray-400 flex items-center justify-center gap-1 mt-1">
        {icon} {label}
      </div>
      {!show && isEditMode && (
        <div className="text-xs text-gray-500 mt-1">Hidden</div>
      )}
    </div>
  );
}

// Social Link Input Component
function SocialLinkInput({
  icon,
  label,
  value,
  onChange,
  placeholder,
  error,
}: {
  icon: React.ReactNode;
  label: string;
  value: string;
  onChange: (value: string) => void;
  placeholder: string;
  error?: string;
}) {
  return (
    <div>
      <label className="flex items-center gap-2 text-sm font-semibold mb-2">
        {icon} {label}
      </label>
      <input
        type="url"
        value={value}
        onChange={(e) => onChange(e.target.value)}
        className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 focus:border-red-500 focus:outline-none"
        placeholder={placeholder}
      />
      {error && (
        <p className="text-red-500 text-sm mt-1">{error}</p>
      )}
    </div>
  );
}
