        // Skip non-collaborator fields
        if (!categoryData || typeof categoryData !== 'object') return null;
        
        // Extract collaborators array from different formats
        let collaborators = [];
        
        // Format 1: Prabhas (nested with multipleFilms)
        if (categoryData.multipleFilms && Array.isArray(categoryData.multipleFilms)) {
          collaborators = categoryData.multipleFilms;
        }
        // Format 2 & 3: Others (direct arrays)
        else if (Array.isArray(categoryData)) {
          collaborators = categoryData;
        }
        // Skip if nested object without multipleFilms (like producers section)
