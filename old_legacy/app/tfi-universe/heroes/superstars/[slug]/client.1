          <div className="relative border-l-2 border-[#E50914]/30 ml-4 space-y-8">
            {hero.careerMilestones.map((milestone: any, index: number) => (
              <div key={index} className="relative pl-8">
                {/* Timeline dot */}
                <div className="absolute -left-[9px] top-2 w-4 h-4 rounded-full bg-[#E50914] border-4 border-black" />
                
                <div className="rounded-xl p-5 bg-zinc-900/30 border border-white/[0.06]">
