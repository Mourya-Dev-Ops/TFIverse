function MoviesTab({ movies, hero }: any) {
  const [filter, setFilter] = useState('all');
  const [sortBy, setSortBy] = useState('year');

  const { allMovies, leadCount, cameoCount, voiceoverCount, childCount } = useMemo(() => {
    const all = movies || [];
    const lead = all.filter((m: any) => m.movieType?.toLowerCase() === 'lead' || m.role?.toLowerCase() === 'lead' || !m.movieType);
    const cameo = hero?.cameoAppearances || [];
    const voiceover = hero?.voiceOverAppearances || [];
    const child = hero?.childArtistMovies || [];

    return {
      allMovies: all,
      leadCount: lead.length,
      cameoCount: cameo.length,
      voiceoverCount: voiceover.length,
      childCount: child.length
    };
  }, [movies, hero]);

  const filteredMovies = useMemo(() => {
    let filtered = [];
    
    if (filter === 'all') {
      filtered = [...allMovies, ...(hero?.cameoAppearances || []), ...(hero?.voiceOverAppearances || []), ...(hero?.childArtistMovies || [])];
    } else if (filter === 'lead') {
      filtered = allMovies.filter((m: any) => m.movieType?.toLowerCase() === 'lead' || m.role?.toLowerCase() === 'lead' || !m.movieType);
    } else if (filter === 'cameo') {
      filtered = hero?.cameoAppearances || [];
    } else if (filter === 'voiceover') {
      filtered = hero?.voiceOverAppearances || [];
    } else if (filter === 'child') {
      filtered = hero?.childArtistMovies || [];
    }

    return filtered.sort((a: any, b: any) => {
      if (sortBy === 'year') return (b.year || 0) - (a.year || 0);
      if (sortBy === 'rating') return (b.ratings?.imdb || 0) - (a.ratings?.imdb || 0);
      return 0;
    });
  }, [allMovies, hero, filter, sortBy]);

  return (
    <div>
      <div className="flex items-center justify-between mb-8 flex-wrap gap-4">
        <div className="flex gap-2 flex-wrap">
          <FilterButton active={filter === 'all'} onClick={() => setFilter('all')}>
            All ({allMovies.length + cameoCount + voiceoverCount + childCount})
          </FilterButton>
          <FilterButton active={filter === 'lead'} onClick={() => setFilter('lead')}>
            Lead ({leadCount})
          </FilterButton>
          {childCount > 0 && (
            <FilterButton active={filter === 'child'} onClick={() => setFilter('child')}>
              Child Artist ({childCount})
            </FilterButton>
          )}
          {cameoCount > 0 && (
            <FilterButton active={filter === 'cameo'} onClick={() => setFilter('cameo')}>
              Cameo ({cameoCount})
            </FilterButton>
          )}
          {voiceoverCount > 0 && (
            <FilterButton active={filter === 'voiceover'} onClick={() => setFilter('voiceover')}>
              Voice-Over ({voiceoverCount})
            </FilterButton>
          )}
        </div>
        <select value={sortBy} onChange={(e) => setSortBy(e.target.value)}
          className="px-4 py-2 bg-zinc-900 text-white rounded-lg border border-white/10 outline-none">
          <option value="year">Sort by Year</option>
          <option value="rating">Sort by Rating</option>
        </select>
      </div>

      {filteredMovies.length === 0 ? (
        <div className="text-white/40 text-center py-20">No movies found</div>
      ) : (
        <div className="grid md:grid-cols-4 lg:grid-cols-5 gap-6">
          {filteredMovies.map((movie: any, index: number) => (
            <MovieCard key={movie.slug || movie.id || index} movie={movie} />
          ))}
        </div>
      )}
    </div>
  );
}

function MovieCard({ movie }: any) {
  const [posterUrl, setPosterUrl] = useState<string>('');
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const loadPoster = async () => {
      setLoading(true);
      
      if (typeof movie.poster === 'string') {
        if (movie.poster.startsWith('/')) {
          setPosterUrl(`${TMDB_IMAGE_BASE}${movie.poster}`);
        } else if (movie.poster.startsWith('http')) {
          setPosterUrl(movie.poster);
        } else {
          setPosterUrl('/images/no-poster.png');
        }
        setLoading(false);
        return;
      }

      if (movie.poster?.source === 'local' && movie.tmdbId && movie.tmdbId > 0) {
        try {
          const res = await fetch(`https://api.themoviedb.org/3/movie/${movie.tmdbId}?api_key=${TMDB_API_KEY}`);
          const data = await res.json();
          if (data.poster_path) {
            setPosterUrl(`${TMDB_IMAGE_BASE}${data.poster_path}`);
          } else {
            setPosterUrl('/images/no-poster.png');
          }
        } catch {
          setPosterUrl('/images/no-poster.png');
        }
        setLoading(false);
        return;
      }

      if (movie.poster?.url) {
        if (movie.poster.url.startsWith('/')) {
          setPosterUrl(`${TMDB_IMAGE_BASE}${movie.poster.url}`);
        } else {
          setPosterUrl(movie.poster.url);
        }
        setLoading(false);
        return;
      }

      if (movie.tmdbId && movie.tmdbId > 0) {
        try {
          const res = await fetch(`https://api.themoviedb.org/3/movie/${movie.tmdbId}?api_key=${TMDB_API_KEY}`);
          const data = await res.json();
          if (data.poster_path) {
            setPosterUrl(`${TMDB_IMAGE_BASE}${data.poster_path}`);
          } else {
            setPosterUrl('/images/no-poster.png');
          }
        } catch {
          setPosterUrl('/images/no-poster.png');
        }
        setLoading(false);
        return;
      }

      setPosterUrl('/images/no-poster.png');
      setLoading(false);
    };

    loadPoster();
  }, [movie.poster, movie.tmdbId]);

  return (
    <Link href={`/movie/${movie.slug}`} className="group block">
      <div className="relative rounded-lg overflow-hidden mb-3 shadow-xl border border-white/[0.05] hover:border-white/20 transition-all">
        {loading ? (
          <div className="w-full h-[320px] bg-zinc-900 flex items-center justify-center">
            <FaSpinner className="text-white animate-spin text-2xl" />
          </div>
        ) : (
          <img 
            src={posterUrl} 
            alt={movie.title}
            className="w-full h-[320px] object-cover group-hover:scale-105 transition-transform duration-500"
            onError={(e) => {
              e.currentTarget.src = '/images/no-poster.png';
            }}
          />
        )}
        
        <div className="absolute top-2 left-2 px-2 py-1 rounded-md bg-black/80 text-white text-xs font-bold">
          {movie.year}
        </div>

        {movie.ratings?.imdb && (
          <div className="absolute top-2 right-2 px-2 py-1 rounded-md bg-yellow-500/90 text-black text-xs font-bold flex items-center gap-1">
            <FaStar className="text-xs" />
            {movie.ratings.imdb}
          </div>
        )}
      </div>

      <h3 className="text-white font-bold text-sm line-clamp-2 mb-1 group-hover:text-[#E50914] transition">
        {movie.title}
      </h3>
      
      {movie.role && <span className="text-white/40 text-xs">{movie.role}</span>}
    </Link>
  );
}

