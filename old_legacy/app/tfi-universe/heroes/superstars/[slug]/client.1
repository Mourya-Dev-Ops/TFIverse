function TabNavigation({ activeTab, setActiveTab, hero }: any) {
  const scrollContainerRef = useRef<HTMLDivElement>(null);
  
  // ✅ Tab definitions with proper counts
  const tabs = [
    { id: 'info', label: 'Info', icon: FaGlobe },
    { id: 'overview', label: 'Overview', icon: FaUser },
    { id: 'movies', label: 'Movies', count: hero.movies?.length || 0, icon: FaFilm },
    { id: 'upcoming', label: 'Upcoming', count: (hero.upcomingProjects?.length || hero.upcoming?.length || 0), icon: FaCalendarAlt },
    { id: 'lifestyle', label: 'Lifestyle', count: hero.lifestyle ? (hero.lifestyle.carCollection?.length || 0) + (hero.lifestyle.properties?.length || 0) : 0, icon: FaCar },
    { id: 'philanthropy', label: 'Philanthropy', icon: FaHandHoldingHeart },
    { id: 'brands', label: 'Brands', count: hero.brandEndorsements?.length || 0, icon: FaHashtag },
    { id: 'career', label: 'Career', icon: FaChartLine },
    { id: 'awards', label: 'Awards', count: hero.awards?.length || 0, icon: FaAward },
    { id: 'news', label: 'News', count: hero.recentNews?.length || 0, icon: FaNewspaper },
    { id: 'trivia', label: 'Trivia', icon: FaLightbulb },
    { id: 'gallery', label: 'Gallery', count: hero.images?.gallery?.length || 0, icon: FaPalette }
  ];

  // ✅ Auto-scroll to active tab
  useEffect(() => {
    const activeTabElement = scrollContainerRef.current?.querySelector(`[data-tab="${activeTab}"]`);
    if (activeTabElement) {
      activeTabElement.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }, [activeTab]);

  // ✅ Keyboard navigation (Arrow keys)
  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      const currentIndex = tabs.findIndex(t => t.id === activeTab);
      
      if (e.key === 'ArrowLeft' && currentIndex > 0) {
        setActiveTab(tabs[currentIndex - 1].id);
      } else if (e.key === 'ArrowRight' && currentIndex < tabs.length - 1) {
        setActiveTab(tabs[currentIndex + 1].id);
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [activeTab, tabs, setActiveTab]);

  // ✅ Manual scroll function for arrow buttons
  const scroll = (direction: 'left' | 'right') => {
    if (scrollContainerRef.current) {
      scrollContainerRef.current.scrollBy({
        left: direction === 'left' ? -300 : 300,
        behavior: 'smooth'
      });
    }
  };

  return (
    <div className="sticky top-[72px] z-40 bg-black/95 backdrop-blur-xl border-b border-white/[0.06]">
      <div className="max-w-7xl mx-auto px-6 md:px-12 relative">
        {/* Left Arrow Button */}
        <button
          onClick={() => scroll('left')}
          className="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-full bg-gradient-to-r from-black via-black to-transparent flex items-center justify-center text-white hover:text-[#E50914] transition"
          aria-label="Scroll left"
        >
          <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="3" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        {/* Tabs Container with Horizontal Scroll */}
        <div 
          ref={scrollContainerRef}
          className="flex gap-2 overflow-x-auto scrollbar-hide py-4 pb-2 px-10 scroll-smooth"
        >
          {tabs.map((tab) => {
            const Icon = tab.icon;
            return (
              <button 
                key={tab.id}
                data-tab={tab.id}
                onClick={() => setActiveTab(tab.id)}
                className={`flex items-center gap-2 px-4 py-2.5 rounded-lg font-semibold transition whitespace-nowrap ${
                  activeTab === tab.id ? 'bg-[#E50914] text-white' : 'text-white/60 hover:text-white hover:bg-white/10'
                }`}
              >
                {Icon && <Icon className="text-sm" />}
                {tab.label}
                {tab.count !== undefined && tab.count > 0 && (
                  <span className="px-2 py-0.5 bg-white/20 rounded-full text-xs font-bold">{tab.count}</span>
                )}
              </button>
            );
          })}
        </div>

        {/* Right Arrow Button */}
        <button
          onClick={() => scroll('right')}
          className="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-full bg-gradient-to-l from-black via-black to-transparent flex items-center justify-center text-white hover:text-[#E50914] transition"
          aria-label="Scroll right"
        >
          <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="3" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

        {/* Keyboard Navigation Hint */}
        <div className="absolute bottom-1 right-12 text-white/20 text-[10px] pointer-events-none hidden md:block">
          Use ← → keys
        </div>
      </div>

      {/* Hide Scrollbar CSS */}
      <style jsx>{`
        .scrollbar-hide::-webkit-scrollbar {
          display: none;
        }
        .scrollbar-hide {
          -ms-overflow-style: none;
          scrollbar-width: none;
        }
      `}</style>
    </div>
  );
}

