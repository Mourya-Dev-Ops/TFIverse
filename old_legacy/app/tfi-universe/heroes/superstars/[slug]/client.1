                    <span className="inline-block px-3 py-1 bg-[#E50914]/20 text-[#E50914] rounded-full text-xs font-bold mb-3">
                      {milestone.year}
                    </span>
                  )}
                  
                  <h3 className="text-white font-bold text-lg mb-2">{milestone.achievement}</h3>
                  
                  {milestone.description && (
                    <p className="text-white/80 text-sm mb-3">{milestone.description}</p>
                  )}
                  
                  {milestone.significance && (
                    <div className="mt-3 p-3 bg-black/30 rounded-lg border border-white/[0.06]">
                      <p className="text-white/60 text-xs mb-1">Significance:</p>
                      <p className="text-white/80 text-sm">{milestone.significance}</p>
                    </div>
                  )}
                  
                  {milestone.films && Array.isArray(milestone.films) && (
                    <div className="mt-3 flex flex-wrap gap-2">
                      {milestone.films.map((film: string, i: number) => (
                        <span key={i} className="px-2 py-1 bg-white/10 text-white/70 rounded text-xs">
                          {film}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Collaborations - FIXED TO HANDLE OBJECT FORMAT */}
      {hero.collaborations && typeof hero.collaborations === 'object' && (
        <section>
          <h2 className="text-3xl font-black text-white mb-6">Notable Collaborations</h2>
          <div className="grid md:grid-cols-2 gap-6">
            {Object.entries(hero.collaborations).map(([category, people]: any) => {
              // Skip if not an array or is empty
              if (!Array.isArray(people) || people.length === 0) return null;
              
              // Format category name
              const categoryName = category
                .replace(/([A-Z])/g, ' $1')
                .replace(/^./, str => str.toUpperCase())
                .trim();
              
              return (
                <div key={category} className="rounded-xl p-6 bg-zinc-900/30 border border-white/[0.06]">
                  <h3 className="text-white font-bold text-lg mb-4 flex items-center gap-2">
                    {category === 'directors' && '🎬'}
                    {category === 'musicDirectors' && '🎵'}
                    {category === 'actresses' && '👩'}
                    {category === 'actors' && '👨'}
                    {categoryName}
                  </h3>
                  <div className="space-y-2">
                    {people.slice(0, 10).map((person: any, i: number) => {
  // Extract name - handle ALL possible field names
  const name = typeof person === 'string' 
    ? person 
    : person.name || person.director || person.composer || person.actress || person.actor || 'Unknown';
  
  const count = typeof person === 'object' ? person.count || person.films?.length || 1 : 1;
  
  return (
    <div key={i} className="flex items-center justify-between p-2 rounded-lg bg-black/30 hover:bg-black/40 transition">
      <span className="text-white/80 text-sm">{name}</span>
      <span className="px-2 py-0.5 bg-[#E50914]/20 text-[#E50914] rounded-full text-xs font-bold">
        {count}
      </span>
    </div>
  );
})}
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}

      {/* Industry Recognition */}
      {hero.industryRecognition && hero.industryRecognition.length > 0 && (
        <section>
          <h2 className="text-3xl font-black text-white mb-6">Industry Recognition</h2>
          <div className="grid md:grid-cols-2 gap-4">
            {hero.industryRecognition.map((recognition: string, index: number) => (
              <div key={index} className="rounded-xl p-4 bg-zinc-900/30 border border-white/[0.06]">
                <p className="text-white/80">🏆 {recognition}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Box Office Stats */}
      {hero.boxOfficeStats && (
        <section>
          <h2 className="text-3xl font-black text-white mb-6">Box Office Performance</h2>
          <div className="grid md:grid-cols-3 gap-6">
            {hero.boxOfficeStats.totalGross && (
              <div className="rounded-xl p-6 bg-gradient-to-br from-[#E50914]/20 to-red-600/20 border border-[#E50914]/30">
                <p className="text-white/60 text-sm mb-2">Total Gross</p>
                <p className="text-white font-black text-3xl">{hero.boxOfficeStats.totalGross}</p>
              </div>
            )}
            {hero.boxOfficeStats.averagePerFilm && (
              <div className="rounded-xl p-6 bg-zinc-900/30 border border-white/[0.06]">
                <p className="text-white/60 text-sm mb-2">Average Per Film</p>
                <p className="text-white font-black text-2xl">{hero.boxOfficeStats.averagePerFilm}</p>
              </div>
            )}
            {hero.boxOfficeStats.highestGrosser && (
              <div className="rounded-xl p-6 bg-zinc-900/30 border border-white/[0.06]">
                <p className="text-white/60 text-sm mb-2">Highest Grosser</p>
                <p className="text-white font-bold text-lg">{hero.boxOfficeStats.highestGrosser.title}</p>
                <p className="text-[#E50914] font-bold">{hero.boxOfficeStats.highestGrosser.gross}</p>
              </div>
            )}
          </div>
        </section>
      )}

      {/* Debut Information */}
      {hero.personalInfo?.debut && (
        <section>
          <h2 className="text-3xl font-black text-white mb-6">Career Debut</h2>
          <div className="rounded-xl p-6 bg-zinc-900/30 border border-white/[0.06]">
            <h3 className="text-white font-bold text-xl mb-2">{hero.personalInfo.debut.film}</h3>
            <div className="flex items-center gap-4 text-white/60 text-sm mb-3">
              {hero.personalInfo.debut.year && <span>📅 {hero.personalInfo.debut.year}</span>}
              {hero.personalInfo.debut.role && <span>🎭 {hero.personalInfo.debut.role}</span>}
            </div>
            {hero.personalInfo.debut.director && (
              <p className="text-white/80">
                <span className="text-white/60">Directed by:</span> {hero.personalInfo.debut.director}
              </p>
            )}
          </div>
        </section>
      )}
    </div>
  );
}


