              {collaborators.slice(0, 6).map((person: any, index: number) => {
                // Extract name (handles all formats)
                const personName = person.name || person.director || person.composer || person.actress || 'Unknown';
                
                // Extract count (handles all formats)
                let filmCount = 0;
